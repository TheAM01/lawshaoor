# Admin login (used by /admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please

# iron-session cookie secret (MIN 32 characters)
SESSION_SECRET=replace-with-32-char-or-longer-random-string

# MongoDB connection URI. Database name can come from the URI or default to "lawshaoor".
MONGODB_URI=mongodb+srv://USER:PASS@HOST/lawshaoor

# ImgBB API key for image uploads (https://api.imgbb.com/)
IMGBB_API_KEY=your-imgbb-api-key
